rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin roster, each user may read only their own record
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Campus paths are world readable for routing, admins only for writes
    match /artifacts/{appId}/public/data/shortcuts/{shortcutId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly(['geometry', 'properties'])
        && request.resource.data.geometry is string
        && request.resource.data.geometry.size() > 0
        && request.resource.data.geometry.size() < 100000
        && request.resource.data.properties.keys().hasOnly(['creator', 'timestamp'])
        && request.resource.data.properties.creator == request.auth.uid
        && request.resource.data.properties.timestamp is string;
      allow delete: if isAdmin();
    }

  }
}
