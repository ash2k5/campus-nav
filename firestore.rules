rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin roster, each user may read only their own record
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Campus paths are world readable for routing, admins only for writes
    match /artifacts/{appId}/public/data/shortcuts/{shortcutId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.properties.creator == request.auth.uid;
      allow delete: if isAdmin();
    }

  }
}
